# Shared
NODE_ENV=development

# Frontend
VITE_API_BASE_URL=http://localhost:4000
# Supabase project URL (Project Settings -> API -> Project URL)
VITE_SUPABASE_URL=
# Supabase anon public key (Project Settings -> API -> anon key)
VITE_SUPABASE_ANON_KEY=

# Backend
PORT=4000
APP_ORIGIN=http://localhost:5173
# Same Supabase project URL used by frontend
SUPABASE_URL=
# Same anon key used by frontend
SUPABASE_ANON_KEY=
# Supabase service role key (Project Settings -> API -> service_role key)
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:5173/dashboard?checkout=success
STRIPE_CANCEL_URL=http://localhost:5173/subscribe?checkout=cancel
